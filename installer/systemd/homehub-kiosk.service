[Unit]
Description=HomeHub touch appliance display
After=systemd-user-sessions.service homehub-server.service
Requires=homehub-server.service
Conflicts=getty@tty1.service
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStartPre=/bin/sleep 2
ExecStart=/usr/bin/cage -- /opt/homehub/current/installer/kiosk-session.sh
Restart=always
RestartSec=2
StandardInput=tty
TTYPath=/dev/tty1
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes
Environment=XDG_RUNTIME_DIR=/run/homehub-kiosk
Environment=HOMEHUB_APP_ROOT=/opt/homehub/current
Environment=HOMEHUB_STATE_DIR=/var/lib/homehub
Environment=PYTHONPATH=/opt/homehub/current/backend
RuntimeDirectory=homehub-kiosk
RuntimeDirectoryMode=0700

[Install]
WantedBy=multi-user.target
